# ChainStream GraphQL API key. Required.
# Get one at: https://chainstream.io
CHAINSTREAM_API_KEY=

# Optional: Claude reasoning layer. If unset, scanner skips AI verdicts.
ANTHROPIC_API_KEY=

# Optional overrides
CHAINSTREAM_GRAPHQL_ENDPOINT=https://graphql.chainstream.io/graphql
WHALE_PULSE_LOOKBACK_MINUTES=15
WHALE_PULSE_MIN_USD=100000
WHALE_PULSE_CHAINS=ethereum,polygon,bsc,arbitrum
